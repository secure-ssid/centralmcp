{
  "mcpServers": {
    "aruba-tool-router": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/tool_router.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CREDS_PATH": "${workspaceFolder}/config/credentials.yaml",
        "CENTRALMCP_ROUTER_MODE": "minimal",
        "CENTRALMCP_TOOLSETS": "central,glp,rag"
      }
    }
  }
}
