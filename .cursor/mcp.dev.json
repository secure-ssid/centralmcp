{
  "_note": "Dev variant: exposes all 6 servers directly (full introspection, ~8k tool tokens). Copy over mcp.json while debugging a specific tool, or use alongside the router for raw access.",
  "mcpServers": {
    "obsidian-vault": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/stephenchoate/Documents/Central-MCP-Obsidian"
      ]
    },
    "aruba-monitoring": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/monitoring.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CREDS_PATH": "${workspaceFolder}/config/credentials.yaml"
      }
    },
    "aruba-config": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/config.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CREDS_PATH": "${workspaceFolder}/config/credentials.yaml"
      }
    },
    "aruba-ops": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/ops.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CREDS_PATH": "${workspaceFolder}/config/credentials.yaml"
      }
    },
    "aruba-nac": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/nac.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CREDS_PATH": "${workspaceFolder}/config/credentials.yaml"
      }
    },
    "aruba-glp": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/glp.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CREDS_PATH": "${workspaceFolder}/config/credentials.yaml"
      }
    },
    "aruba-rag": {
      "command": "${workspaceFolder}/.venv/bin/python3",
      "args": ["${workspaceFolder}/mcp_servers/rag.py"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  }
}
