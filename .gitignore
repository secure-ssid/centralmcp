# Credentials — never commit
.env
config/credentials.yaml
.token_cache_*.json

# Claude local settings (may contain credentials in allowed commands)
.claude/settings.local.json

# Local MCP client configs (often include absolute paths/secrets)
# Keep shared settings in .mcp.json.example only.
.mcp.json
.cursor/mcp.json
.claude/mcp.json
.vscode/mcp.json

# Local cross-agent handoff state (copy from SESSION_CONTEXT.md.example)
SESSION_CONTEXT.md

# Internal runbook PDFs
*.pdf

# Postman collections (large binary-like files — download via resources/README.md)
resources/*.json

# Real device input files (use inputs/*_example.csv as templates instead)
inputs/*.csv
inputs/*.cfg
!inputs/*_example.csv
!inputs/*_template.csv

# macOS metadata
.DS_Store

# Runtime output
state/
outputs/
!state/.gitkeep
!outputs/.gitkeep

# Node (orphan lockfiles from Claude worktree sessions)
package-lock.json
package.json
node_modules/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
