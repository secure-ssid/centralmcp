{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "aruba-monitoring MCP server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "mcp_servers.monitoring"]
    },
    {
      "name": "aruba-config MCP server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "mcp_servers.config"]
    },
    {
      "name": "aruba-ops MCP server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "mcp_servers.ops"]
    },
    {
      "name": "aruba-nac MCP server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "mcp_servers.nac"]
    },
    {
      "name": "aruba-glp MCP server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "mcp_servers.glp"]
    },
    {
      "name": "Migration pipeline (CLI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["run_pipeline.py", "--input", "inputs/migration_example.csv"]
    },
    {
      "name": "SSID builder (CLI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["run_ssid.py"]
    }
  ]
}
