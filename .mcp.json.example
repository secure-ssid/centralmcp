{
  "mcpServers": {
    "aruba-tool-router": {
      "command": "/path/to/centralmcp/.venv/bin/python3",
      "args": [
        "/path/to/centralmcp/mcp_servers/tool_router.py"
      ],
      "cwd": "/path/to/centralmcp",
      "env": {
        "PYTHONPATH": "/path/to/centralmcp",
        "CREDS_PATH": "/path/to/centralmcp/config/credentials.yaml",
        "CENTRALMCP_ROUTER_MODE": "minimal",
        "CENTRALMCP_TOOLSETS": "central,glp,rag"
      }
    }
  }
}
