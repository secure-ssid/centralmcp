# Copy this file to credentials.yaml and fill in your values.
# credentials.yaml is gitignored — never commit real credentials.
#
# Preferred (MCP-era) key names:
#   central_account — the Central / New Central OAuth2 client
#   glp_account     — the HPE GreenLake Platform OAuth2 client
#
# Legacy key names (still accepted for back-compat with the cross-account
# migration pipeline):
#   source_account  — alias for central_account
#   target_account  — alias for glp_account
#
# If both are present in the same file, the legacy pair wins so existing
# installs don't see a surprise rename.
#
# Alternatively, set the equivalent environment variables (they take
# precedence over any YAML value):
#   SOURCE_BASE_URL,  SOURCE_CLIENT_ID,  SOURCE_CLIENT_SECRET,  SOURCE_GLP_WORKSPACE
#   TARGET_BASE_URL,  TARGET_CLIENT_ID,  TARGET_CLIENT_SECRET,  TARGET_GLP_WORKSPACE
#   GLP_TOKEN_URL,    GLP_BASE_URL

central_account:
  base_url: https://internal.api.central.arubanetworks.com
  client_id: YOUR_CENTRAL_CLIENT_ID
  client_secret: YOUR_CENTRAL_CLIENT_SECRET
  glp_workspace_id: YOUR_GLP_WORKSPACE_ID

glp_account:
  base_url: https://internal.api.central.arubanetworks.com
  client_id: YOUR_GLP_CLIENT_ID
  client_secret: YOUR_GLP_CLIENT_SECRET
  glp_workspace_id: YOUR_GLP_WORKSPACE_ID

glp:
  token_url: https://sso.common.cloud.hpe.com/as/token.oauth2
  base_url: https://global.api.greenlake.hpe.com
